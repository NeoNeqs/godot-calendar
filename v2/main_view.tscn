[sub_resource type="GDScript" id="GDScript_8iklj"]
script/source = "extends PanelContainer

signal snapped(direction: int)

signal snap_ended()

@onready var scroll_container: ScrollContainer = $ScrollContainer
@onready var content: Control = null

var pressed: bool = false
var scroll_speed := Vector2.ZERO
var axis_locked: int = 0 # 0 = none, 1 = horizontal, 2 = vertical
var last_motion := Vector2.ZERO
var cumulative_motion := Vector2.ZERO

var dragging: bool = false
var drag_start_h: float = 0.0

var snapping: bool = false
var snap_start_h: float = 0.0
var snap_target_h: float = 0.0
var snap_elapsed: float = 0.0

var block_snap_left: bool = false   # prevents going to previous page
var block_snap_right: bool = false  # prevents going to next page

const DEADZONE: float = 6.0
const SENSITIVITY: float = 0.7
const INERTIA_MULTIPLIER: float = 2.5
const MAX_SPEED: float = 6000.0
const DECAY: float = 4.5
const MIN_SPEED: float = 30.0

# fraction of viewport width required to change column
const SNAP_THRESHOLD_RATIO: float = 0.3
const SNAP_DURATION: float = 0.20
const SNAP_VELOCITY_THRESHOLD: float = 250.0  # optional: px/sec to force snap on quick fling

func _ready() -> void:
	set_process(true)
	if scroll_container and scroll_container.get_child_count() > 0:
		content = scroll_container.get_child(0) as Control

func _draw() -> void:
	draw_line(Vector2(0, 2), Vector2(size.x, 2), Color(\"1e293b\"), 4)
	draw_line(Vector2(75, 0), Vector2(75, size.y), Color(\"1e293b\"), 4)

func _gui_input(event: InputEvent) -> void:
	if snapping:
		return
	if event is InputEventMouseButton:
		_handle_mouse_button(event as InputEventMouseButton)
	elif event is InputEventMouseMotion:
		_handle_mouse_motion(event as InputEventMouseMotion)

func set_horizontal_block(left: bool, right: bool) -> void:
	block_snap_left = left
	block_snap_right = right

# --- input helpers --------------------------------------------------------

func _handle_mouse_button(ev: InputEventMouseButton) -> void:
	if ev.button_index != MOUSE_BUTTON_LEFT:
		return
	if ev.pressed:
		_on_drag_start()
	else:
		_on_drag_release()

func _handle_mouse_motion(motion: InputEventMouseMotion) -> void:
	if not pressed:
		return
	var rel: Vector2 = motion.relative * SENSITIVITY
	last_motion = rel
	cumulative_motion += rel

	# If axis not decided yet, wait until buffered motion crosses deadzone.
	if axis_locked == 0:
		if cumulative_motion.length() <= DEADZONE:
			return
		# Decide axis from the buffered motion and apply buffered movement along that axis.
		axis_locked = 1 if absf(cumulative_motion.x) > absf(cumulative_motion.y) else 2
		var initial_rel := Vector2.ZERO
		if axis_locked == 1:
			initial_rel.x = cumulative_motion.x
		else:
			initial_rel.y = cumulative_motion.y
		_apply_scroll(initial_rel)
		scroll_speed = _clamped_velocity_from_rel(initial_rel)
		_enforce_axis_on_speed()
		cumulative_motion = Vector2.ZERO
		return

	# Axis already chosen: zero non-locked axis and apply current rel
	if axis_locked == 1:
		rel.y = 0
	else:
		rel.x = 0
	_apply_scroll(rel)
	scroll_speed = _clamped_velocity_from_rel(rel)
	_enforce_axis_on_speed()

func _on_drag_start() -> void:
	pressed = true
	dragging = true
	axis_locked = 0
	scroll_speed = Vector2.ZERO
	last_motion = Vector2.ZERO
	cumulative_motion = Vector2.ZERO
	if scroll_container:
		drag_start_h = float(scroll_container.get_h_scroll())

func _on_drag_release() -> void:
	pressed = false
	dragging = false
	if axis_locked == 0:
		# determine axis from buffered motion or residual speed
		if cumulative_motion.length() > 0.0:
			axis_locked = 1 if absf(cumulative_motion.x) > absf(cumulative_motion.y) else 2
		elif scroll_speed.length() > 0.0:
			axis_locked = 1 if absf(scroll_speed.x) > absf(scroll_speed.y) else 2
	_enforce_axis_on_speed()
	if axis_locked == 1:
		_start_horizontal_snap_from_drag()
	cumulative_motion = Vector2.ZERO

# --- velocity / helpers --------------------------------------------------

func _clamped_velocity_from_rel(rel: Vector2) -> Vector2:
	var v: Vector2 = rel * 60.0 * INERTIA_MULTIPLIER
	var speed: float = v.length()
	if speed > MAX_SPEED and speed > 0.0:
		v = v.normalized() * MAX_SPEED
	return v

func _enforce_axis_on_speed() -> void:
	if axis_locked == 1:
		scroll_speed.y = 0
	elif axis_locked == 2:
		scroll_speed.x = 0

# --- process / inertia / snap -------------------------------------------

func _process(delta: float) -> void:
	if snapping:
		_update_snap(delta)
		return
	_handle_inertia(delta)

func _handle_inertia(delta: float) -> void:
	if pressed or scroll_speed.length() <= MIN_SPEED:
		return
	if axis_locked == 0:
		if scroll_speed.length() > 0.0:
			axis_locked = 1 if absf(scroll_speed.x) > absf(scroll_speed.y) else 2
		_enforce_axis_on_speed()

	var move: Vector2 = scroll_speed * delta
	if axis_locked == 1:
		move.y = 0
	else:
		move.x = 0
	_apply_scroll(move)

	# exponential decay
	var decay_factor: float = exp(-DECAY * delta)
	scroll_speed *= decay_factor

	if scroll_speed.length() <= MIN_SPEED:
		scroll_speed = Vector2.ZERO
		axis_locked = 0

func _update_snap(delta: float) -> void:
	snap_elapsed += delta
	var t: float = clampf(snap_elapsed / SNAP_DURATION, 0.0, 1.0)
	var eased: float = 1.0 - pow(1.0 - t, 3) # ease-out cubic
	var new_h: float = lerpf(snap_start_h, snap_target_h, eased)
	scroll_container.set_h_scroll(int(new_h))
	if t >= 1.0:
		snap_ended.emit()
		snapping = false
		axis_locked = 0
		scroll_speed = Vector2.ZERO

# --- snapping logic -----------------------------------------------------

func _start_horizontal_snap_from_drag() -> void:
	if not scroll_container or not content:
		return

	var vw := float(scroll_container.size.x)
	if vw <= 0.0:
		return

	var release_h := float(scroll_container.get_h_scroll())
	var delta_h: float = release_h - drag_start_h
	var delta_fraction: float = delta_h / vw
	var threshold_frac: float = SNAP_THRESHOLD_RATIO

	var max_index: int = floori(content.size.x / vw)
	var start_index: int = clampi(floori((drag_start_h + vw * 0.5) / vw), 0, max_index)
	var target_index: int = start_index

	# --- Threshold based snap ---
	if delta_fraction >= threshold_frac:
		target_index = clampi(start_index + 1, 0, max_index)
	elif delta_fraction <= -threshold_frac:
		target_index = clampi(start_index - 1, 0, max_index)
	else:
		# --- Velocity override snap ---
		if absf(scroll_speed.x) >= SNAP_VELOCITY_THRESHOLD:
			var fling_dir: int = -int(signf(scroll_speed.x))
			target_index = clampi(start_index + fling_dir, 0, max_index)

	# ---------------------------------
	# Detect if snap actually changed page
	# ---------------------------------
	var did_snap := target_index != start_index
	var snap_direction := signi(target_index - start_index)
	
	# Block direction if needed
	if snap_direction < 0 and block_snap_left:
		target_index = start_index
	elif snap_direction > 0 and block_snap_right:
		target_index = start_index

	if did_snap:
		snapped.emit(snap_direction) # emit -1 or +1

	# Start snap animation
	var target_h := float(target_index) * vw
	snapping = true
	snap_elapsed = 0.0
	snap_start_h = float(scroll_container.get_h_scroll())
	snap_target_h = clampf(target_h, 0.0, maxf(0.0, content.size.x - vw))
	scroll_speed = Vector2.ZERO
	axis_locked = 1
# --- low-level scrolling -----------------------------------------------

func _apply_scroll(delta_pos: Vector2) -> void:
	if not scroll_container or not content:
		return
	var max_h: float = maxf(0.0, content.size.x - scroll_container.size.x)
	var max_v: float = maxf(0.0, content.size.y - scroll_container.size.y)
	var h := float(scroll_container.get_h_scroll())
	var v := float(scroll_container.get_v_scroll())
	h = clampf(h - delta_pos.x, 0.0, max_h)
	v = clampf(v - delta_pos.y, 0.0, max_v)
	scroll_container.set_h_scroll(int(h))
	scroll_container.set_v_scroll(int(v))
"

