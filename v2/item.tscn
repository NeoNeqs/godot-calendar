[sub_resource type="GDScript" id="GDScript_bjewl"]
script/source = "@tool
extends HBoxContainer

@export var icon_panel: PanelContainer
@export var icon: TextureRect
@export var start_time: Label
@export var end_time: Label

@export var item_panel: PanelContainer
@export var info: Label
@export var lecture: Label
@export var room: Label

@export var details: Label
@export var time_left: Label

@export_enum(\"past\", \"now\", \"future\") var state: String = \"past\":
	set(v):
		state = v
		if is_node_ready():
			update2.call_deferred()

@export var has_info: bool = false:
	set(v):
		has_info = v
		if is_node_ready():
			update2.call_deferred()

static var ITEM_PANEL_NORMAL: StyleBoxFlat = load(\"uid://b82uk45b7mhg6\")
static var ITEM_START_TIME_PAST: LabelSettings = load(\"uid://c40l5qmgnf6t2\")
static var ITEM_END_LABEL_PAST: LabelSettings = load(\"uid://dti5gcu5tgkq5\")
static var ITEM_PANEL: StyleBoxFlat = load(\"uid://ddjx6122v8ere\")
static var ITEM_LECTURE_PAST: LabelSettings = load(\"uid://jir4ekfwhoyq\")
static var ITEM_ROOM_PAST: LabelSettings = load(\"uid://hmg4ipc8m3rj\")
static var ITEM_DETAILS_PAST: LabelSettings = load(\"uid://bvcq0m50skjwu\")
static var ITEM_INFO_PAST: StyleBoxFlat = load(\"uid://koawqbd0ljms\")
static var ITEM_PANEL_INFO: StyleBoxFlat = load(\"uid://t2udoc8b3o62\")
static var ITEM_ICON_PANEL_NOW_INFO: StyleBoxFlat = load(\"uid://cn1n57i4jx3q3\")
static var ITEM_ICON_PANEL_NOW: StyleBoxFlat = load(\"uid://c6jxnlg4boqwg\")
static var ITEM_START_TIME_NOW: LabelSettings = load(\"uid://ckt3mf5ixnjlt\")
static var ITEM_START_TIME_NOW_INFO: LabelSettings = load(\"uid://c6ufqhvbrm6qk\")
static var ITEM_END_TIME_NOW: LabelSettings = load(\"uid://6par1rrqr6w3\")
static var ITEM_INFO_NOW: StyleBoxFlat = load(\"uid://dsm5fact0yxtv\")
static var ITEM_LECTURE_NOW_INFO: LabelSettings = load(\"uid://csylxek74ls62\")
static var ITEM_LECTURE_NOW: LabelSettings = load(\"uid://8n8pnxwtn1pw\")
static var ITEM_ROOM_NOW: LabelSettings = load(\"uid://dx4jti36j8t0\")
static var ITEM_DETAILS_NOW: LabelSettings = load(\"uid://bp7ve6q3oisnn\")
static var ITEM_TIME_LEFT_NOW_INFO: LabelSettings = load(\"uid://cwr08yuf4pc6d\")
static var ITEM_TIME_LEFT_NOW_STYLE_INFO: StyleBoxFlat = load(\"uid://dvdn1i1dgao23\")
static var ITEM_TIME_LEFT_NOW_STYLE: StyleBoxFlat = load(\"uid://ds0ng0elbydxk\")
static var ITEM_TIME_LEFT_NOW: LabelSettings = load(\"uid://byo7vv4ctes8i\")
static var ITEM_LECTURE_FUTURE: LabelSettings = load(\"uid://b4d0lpl83tyxx\")
static var ITEM_START_TIME_FUTURE: LabelSettings = load(\"uid://xgjcishk385f\")

func update(item: ScheduleItem) -> void:
	start_time.text = \"%d02:%02d\" % [item.start_time_hours, item.start_time_minutes]
	end_time.text = \"%d02:%02d\" % [item.end_time_hours, item.end_time_minutes]

	info.text = item.info
	lecture.text = item.name
	room.text = item.room

	details.text = \"%s  •  %s\" % [item.type, item.lecturer]
	
	var now = Time.get_datetime_dict_from_system()

	var lecture_start = {
		\"year\": item.year,
		\"month\": item.month - 1,
		\"day\": item.day,
		\"hour\": item.start_time_hours,
		\"minute\": item.start_time_minutes,
		\"second\": 0
	}

	var lecture_end = {
		\"year\": item.year,
		\"month\": item.month - 1,
		\"day\": item.day,
		\"hour\": item.end_time_hours,
		\"minute\": item.end_time_minutes,
		\"second\": 0
	}

	var now_unix = Time.get_unix_time_from_datetime_dict(now)
	var start_unix = Time.get_unix_time_from_datetime_dict(lecture_start)
	var end_unix = Time.get_unix_time_from_datetime_dict(lecture_end)

	if now_unix >= start_unix and now_unix <= end_unix:
		time_left.text = \"%d m left\" % [ceili((end_unix - now_unix) / 60.0)]
		set_now()
	elif now_unix > end_unix:
		set_past()
	else:
		set_future()
	
	if has_info:
		info.show()
		item_panel.add_theme_stylebox_override(\"panel\", ITEM_PANEL_INFO)
	else:
		info.hide()
		item_panel.add_theme_stylebox_override(\"panel\", ITEM_PANEL)


# item: ScheduleItem
func update2() -> void:
	match state:
		\"past\":
			set_past()
		\"now\":
			set_now()
		\"future\":
			set_future()
		_:
			set_now()

func set_past() -> void:
	if has_info:
		info.add_theme_stylebox_override(\"normal\", ITEM_INFO_PAST)
	else:
		info.remove_theme_stylebox_override(\"normal\")
	icon_panel.add_theme_stylebox_override(\"panel\", ITEM_PANEL_NORMAL)
	start_time.label_settings = ITEM_START_TIME_PAST
	end_time.label_settings = ITEM_END_LABEL_PAST
	lecture.label_settings = ITEM_LECTURE_PAST
	room.label_settings = ITEM_ROOM_PAST
	details.label_settings = ITEM_DETAILS_PAST
	time_left.hide()

func set_now() -> void:
	if has_info:
		info.add_theme_stylebox_override(\"normal\", ITEM_INFO_NOW)
		icon_panel.add_theme_stylebox_override(\"panel\", ITEM_ICON_PANEL_NOW_INFO)
		start_time.label_settings = ITEM_START_TIME_NOW_INFO
		lecture.label_settings = ITEM_LECTURE_NOW_INFO
		time_left.label_settings = ITEM_TIME_LEFT_NOW_INFO
		time_left.add_theme_stylebox_override(\"normal\", ITEM_TIME_LEFT_NOW_STYLE_INFO)
	else:
		icon_panel.add_theme_stylebox_override(\"panel\", ITEM_ICON_PANEL_NOW)
		start_time.label_settings = ITEM_START_TIME_NOW
		lecture.label_settings = ITEM_LECTURE_NOW
		time_left.label_settings = ITEM_TIME_LEFT_NOW
		time_left.add_theme_stylebox_override(\"normal\", ITEM_TIME_LEFT_NOW_STYLE)
	end_time.label_settings = ITEM_END_TIME_NOW
	room.label_settings = ITEM_ROOM_NOW
	details.label_settings = ITEM_DETAILS_NOW
	time_left.show()


func set_future() -> void:
	if has_info:
		info.add_theme_stylebox_override(\"normal\", ITEM_INFO_PAST)
	icon_panel.add_theme_stylebox_override(\"panel\", ITEM_PANEL_NORMAL)
	lecture.label_settings = ITEM_LECTURE_FUTURE
	start_time.label_settings = ITEM_START_TIME_FUTURE
	end_time.label_settings = ITEM_END_TIME_NOW
	room.label_settings = ITEM_ROOM_NOW
	details.label_settings = ITEM_DETAILS_NOW
	time_left.hide()
"

