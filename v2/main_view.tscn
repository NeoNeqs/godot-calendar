[sub_resource type="GDScript" id="GDScript_iqtqh"]
script/source = "extends VBoxContainer

@export var reload_button: Button
@export var day_buttons_container: HBoxContainer
@export var selected_date: Label
@export var scroll_container: ScrollContainer
@export var h_box_container: HBoxContainer
@export var previous_day_view_container: VBoxContainer
@export var current_day_view_container: VBoxContainer
@export var next_day_view_container: VBoxContainer
@export var main_view: PanelContainer
# = $MainView

var DAY_BUTTON: PackedScene = load(\"uid://jia2fv56h6tv\")
var ITEM: PackedScene = load(\"uid://dr4yqve67a4pf\")

var config := Config.load_config()

const MAX_DAY_BUTTONS_ON_SCREEN: int = 5

var selected_day_index: int = 0

func _ready() -> void:
	var s := Time.get_ticks_usec()
	reload_button.pressed.connect(_reload)
	await _load()
	if not config.schedule == null:
		_update()
	var e := Time.get_ticks_usec()
	print(e - s)


func _reload() -> void:
	Config.unload()
	await _load()
	if not config.schedule == null:
		_update()


func _load() -> void:
	reload_button.disabled = true
	var schedule_fetcher: ScheduleFetcher = config.load_schedule()
	
	if not schedule_fetcher == null:
		var request: HTTPRequest = schedule_fetcher.fetch()
		add_child(request)
		
		await schedule_fetcher.completed
	
	reload_button.disabled = false

func _update() -> void:
	var day_buttons_scroll_container: Vector2 = day_buttons_container.get_parent_area_size()
	
	# if I don't wait the size is (0, 0) ...
	# There isn't a better way to do this and I will die on that hill.
	while day_buttons_scroll_container.x <= 0:
		day_buttons_scroll_container = day_buttons_container.get_parent_area_size()
		await get_tree().process_frame
	
	var schedule_size: int = config.schedule.items.size()
	var space_between: int = day_buttons_container.get_theme_constant(\"separation\")
	var total_spacing: float = (MAX_DAY_BUTTONS_ON_SCREEN - 1) * space_between
	var day_button_width: float = (day_buttons_scroll_container.x - total_spacing) / float(MAX_DAY_BUTTONS_ON_SCREEN)
	var items: Dictionary[String, Array] = config.schedule.items
	
	scroll_container.resized.connect(update_scroll_container)
	
	_update_object_pool(
		day_buttons_container, 
		DAY_BUTTON, 
		schedule_size, 
		func day_button_update(button: Button) -> void:
			var date: String = items.keys()[button.get_index()]
			
			var datetime: Dictionary = Time.get_datetime_dict_from_datetime_string(date, true)
			button.text = Global.humanize_day(datetime)
			button.custom_minimum_size.x = day_button_width
			
			var on_day_button_toggled: Callable = day_button_toggled.bind(button, date)
			# disconnect!!
			if button.toggled.is_connected(on_day_button_toggled):
				button.toggled.disconnect(on_day_button_toggled)
			button.toggled.connect(on_day_button_toggled)
	)
	day_buttons_container.get_child(0).set_pressed(true)


func day_button_toggled(button_toggled: bool, button: Button, date: String) -> void:
	if not button_toggled:
		return
	print(date)
	var items: Dictionary[String, Array] = config.schedule.items
	
	var datetime: Dictionary = Time.get_datetime_dict_from_datetime_string(date, true)
	
	selected_date.text = Global.humanize_date(datetime)
	selected_day_index = button.get_index()
	
	_update_object_pool(
		current_day_view_container,
		ITEM,
		items[date].size(),
		(func item_update(item: HBoxContainer) -> void:
			item.update(items[date][item.get_index()])
			)
	)

	main_view.set_horizontal_block(selected_day_index == 0, selected_day_index == items.size() - 1)
	
	if selected_day_index - 1 >= 0:
		var arr := items[items.keys()[selected_day_index - 1]]
		_update_object_pool(
			previous_day_view_container,
			ITEM,
			arr.size(),
			(func item_update(item: HBoxContainer) -> void:
				item.update(arr[item.get_index()])
				)
		)
	
	if selected_day_index + 1 < items.size():
		var arr := items[items.keys()[selected_day_index + 1]]
		_update_object_pool(
			next_day_view_container,
			ITEM,
			arr.size(),
			(func item_update(item: HBoxContainer) -> void:
				item.update(arr[item.get_index()])
				)
			)


func update_scroll_container() -> void:
	h_box_container.custom_minimum_size.x = 3 * scroll_container.size.x
	scroll_container.set_h_scroll(int(scroll_container.size.x))


func _update_object_pool(parent: Node, scene: PackedScene, new_size: int, update_callback: Callable) -> void:
	var children_count: int = parent.get_child_count()

	var diff: int = new_size - children_count
	for i: int in maxi(0, diff):
		var node: Node = scene.instantiate()
		parent.add_child(node)
	
	# Children count may change here!
	for i: int in parent.get_child_count():
		var node := parent.get_child(i)
		assert(node is Control)
		if i < new_size:
			update_callback.call(node)
		(node as Control).visible = i < new_size
"

