[sub_resource type="GDScript" id="GDScript_i2mmo"]
script/source = "@tool
extends HBoxContainer


func _ready() -> void:
	get_parent_control().resized.connect(update)

func update() -> void:
	custom_minimum_size.x = 3 * get_parent_control().size.x
	#(get_parent() as ScrollContainer).get_
	(get_parent() as ScrollContainer).set_h_scroll(int(get_parent_control().size.x))
	print(int(get_parent_control().size.x))
"

